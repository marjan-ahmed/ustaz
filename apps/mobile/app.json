{
  "expo": {
    "name": "Ustaz",
    "slug": "ustaz",
    "scheme": "ustaz",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FEF3C7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ustaz.mobile"
    },
    "android": {
      "package": "com.ustaz.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FEF3C7"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Ustaz to use your location for live provider tracking."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ustaz to select photos for profile and warranty evidence."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Ustaz to capture receipt and warranty photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "048c3fb3-03c9-4e47-a77b-1c5524e4f12f"
      }
    },
    "owner": "ustaz-bice"
  }
}
