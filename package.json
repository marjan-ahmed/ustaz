{
    "name": "ustaz",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:web": "npm --workspace @ustaz/web run dev",
        "dev:mobile": "npm --workspace @ustaz/mobile run dev",
        "build:web": "npm --workspace @ustaz/web run build",
        "build:mobile": "npm --workspace @ustaz/mobile run build"
    },
    "devDependencies": {
        "react": "^19.1.0",
        "react-native": "^0.81.5",
        "tailwindcss": "^3.4.19"
    }
}
